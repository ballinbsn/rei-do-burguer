# Copie este arquivo para ".env" e preencha com os valores REAIS.
# NUNCA suba o arquivo ".env" pro GitHub nem cole ele em chat/mensagem.

# Chave secreta da PinPay (painel > Configurações > Chaves de API)
PINPAY_TOKEN=sk_live_coloque_sua_chave_aqui

# Secret usado pra validar a assinatura do webhook (painel > Webhooks)
PINPAY_WEBHOOK_SECRET=whsec_coloque_o_secret_aqui

# URL pública do SEU backend depois de hospedado (ex: Railway, Render, Vercel)
# É pra ela que a PinPay vai mandar o aviso de "pagamento aprovado"
PINPAY_WEBHOOK_URL=https://SEU-DOMINIO-AQUI.com/api/webhooks/pinpay

# Porta local (não precisa mudar)
PORT=3000
